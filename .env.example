# Database
# SQLite default:
DATABASE_URL=sqlite+aiosqlite:///./requirement_space.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/requirement_space

# Runtime environment: development or production
ENV=development

# Frontend origins allowed to send credentialed requests.
# Use comma-separated absolute origins. Wildcards are forbidden in production.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Authentication
AUTH_SESSION_EXPIRE_DAYS=30
# Must be true in production and requires HTTPS.
AUTH_COOKIE_SECURE=false

# Admin registration
# Store an Argon2 hash, never the plaintext invite code.
# Generate with:
# python -c "from backend.core.security import hash_password; print(hash_password('your-invite-code'))"
ADMIN_INVITE_CODE_HASH=

# User LLM credential encryption
# Required at application startup. Generate once and keep it stable:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_CONFIG_ENCRYPTION_KEY=

# Server-level LLM configuration
# Used only by administrator accounts. API URL must not include /v1/chat/completions.
LLM_API_URL=https://api.openai.com
LLM_API_KEY=
LLM_MODEL_NAME=
LLM_TEMPERATURE=0

# Generation backend: legacy or skill
REQUIREMENTSPACE_GENERATION_BACKEND=skill

# Generation concurrency
SCENARIO_GENERATION_MAX_CONCURRENCY=5
KANO_SKILL_MAX_CONCURRENCY=5

# Choice Group generation
GENERATION_CHOICE_CANDIDATE_COUNT=2
GENERATION_CHOICE_MAX_CONCURRENCY=3
GENERATION_CHOICE_TIMEOUT_SECONDS=120
GENERATION_CHOICE_PARTIAL_SUCCESS_MIN=1
GENERATION_CHOICE_GROUP_ENABLED=true
GENERATION_DRAFT_FALLBACK_ENABLED=true
# Comma-separated generation types that should use a single draft.
GENERATION_CHOICE_GROUP_DISABLED_TYPES=
