LLM_API_URL=https://api.openai.com
LLM_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MODEL_NAME=gpt-5.4-mini-2026-03-17
LLM_TEMPERATURE=0
#  legacy表示使用旧的生成方式，skill表示使用新的生成方式
REQUIREMENTSPACE_GENERATION_BACKEND=skill
SCENARIO_GENERATION_MAX_CONCURRENCY=5   # 场景生成的限流参数
KANO_SKILL_MAX_CONCURRENCY=5    # kano分析的限流参数

# Choice Group 多候选生成配置
GENERATION_CHOICE_CANDIDATE_COUNT=2      # 默认候选数量 (1-5)
GENERATION_CHOICE_MAX_CONCURRENCY=3      # 同组候选并发数 (1-8)
GENERATION_CHOICE_TIMEOUT_SECONDS=120    # 单候选超时
GENERATION_CHOICE_PARTIAL_SUCCESS_MIN=1  # 至少成功数下限
GENERATION_CHOICE_GROUP_ENABLED=true     # 总开关: 关闭后所有生成走旧单 draft
GENERATION_DRAFT_FALLBACK_ENABLED=true   # choice group 失败时是否回退旧 draft
GENERATION_CHOICE_GROUP_DISABLED_TYPES=  # 逗号分隔: 不走 choice group 的 generation type (如 "full_scenario")

# --- Authentication & Encryption Config (P0) ---
# Hashed admin invite code (Argon2 hash). Registering as admin requires this code.
# To generate a hash, use security utility hash_password("your_secret_invite_code")
ADMIN_INVITE_CODE_HASH=
# Fernet encryption key for encrypting user API keys (must be 32-byte url-safe base64-encoded)
# You can generate a valid key using: cryptography.fernet.Fernet.generate_key().decode()
LLM_CONFIG_ENCRYPTION_KEY=
# Session expiration in days
AUTH_SESSION_EXPIRE_DAYS=30
# Session cookie secure flag (set to true in production with HTTPS)
AUTH_COOKIE_SECURE=false
# Environment name (development/production)
ENV=development
# Allowed origins for CORS (comma-separated, no wildcards when credentials are true in production)
ALLOWED_ORIGINS=http://localhost:5173
# Session cookie domain (optional, empty by default)
AUTH_COOKIE_DOMAIN=
# Session cookie SameSite setting (lax/strict/none)
AUTH_COOKIE_SAMESITE=lax